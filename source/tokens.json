{
    "_comment": "Maps semantic roles to editor-specific token surfaces. Each port references roles via dot-paths into source/palette.json (e.g. 'syntax.keyword'). Editor-specific overrides live in build/<editor>.mjs.",
    "version": "1.0.1",
    "ui": {
        "_comment": "VS Code workbench color keys → palette role. Light & Dark resolve through the same map.",
        "editor.background": "bg.editor",
        "editor.foreground": "fg.default",
        "editorLineNumber.foreground": "fg.disabled",
        "editorLineNumber.activeForeground": "brand.primary",
        "editor.lineHighlightBackground": "bg.elevated1",
        "editor.selectionBackground": "brand.selectionAlpha",
        "editorCursor.foreground": "brand.primary",
        "sideBar.background": "bg.sidebar",
        "sideBar.foreground": "fg.default",
        "sideBar.border": "border.default",
        "sideBarSectionHeader.background": "bg.sidebar",
        "sideBarSectionHeader.foreground": "fg.default",
        "activityBar.background": "bg.activitybar",
        "activityBar.foreground": "fg.default",
        "activityBar.inactiveForeground": "fg.muted",
        "activityBar.border": "border.default",
        "activityBarBadge.background": "brand.primary",
        "activityBarBadge.foreground": "fg.inverse",
        "statusBar.background": "bg.editor",
        "statusBar.foreground": "fg.muted",
        "statusBar.border": "border.default",
        "statusBar.debuggingBackground": "brand.primary",
        "statusBar.debuggingForeground": "fg.inverse",
        "titleBar.activeBackground": "bg.titlebar",
        "titleBar.activeForeground": "fg.default",
        "titleBar.inactiveBackground": "bg.titlebar",
        "titleBar.inactiveForeground": "fg.subtle",
        "titleBar.border": "border.default",
        "tab.activeBackground": "bg.tabActive",
        "tab.activeForeground": "fg.default",
        "tab.inactiveBackground": "bg.elevated1",
        "tab.inactiveForeground": "fg.muted",
        "tab.border": "border.default",
        "tab.activeBorderTop": "brand.primary",
        "button.background": "brand.primary",
        "button.foreground": "fg.inverse",
        "button.hoverBackground": "brand.primaryHover",
        "focusBorder": "border.strong",
        "list.activeSelectionBackground": "bg.elevated3",
        "list.hoverBackground": "bg.elevated2",
        "list.highlightForeground": "syntax.keyword",
        "list.focusBackground": "brand.focusAlpha",
        "input.background": "bg.input",
        "input.foreground": "fg.default",
        "input.border": "border.default",
        "errorForeground": "state.error",
        "problemsErrorIcon.foreground": "state.error",
        "problemsWarningIcon.foreground": "state.warning",
        "problemsInfoIcon.foreground": "state.infoStrong"
    },
    "syntax": {
        "_comment": "Semantic syntax roles. Each port maps these onto the editor's grammar (TextMate scope, JetBrains attribute key, Treesitter group, etc.).",
        "keyword": {
            "fg": "syntax.keyword"
        },
        "keyword.control": {
            "fg": "syntax.keyword"
        },
        "keyword.operator": {
            "fg": "syntax.operator"
        },
        "keyword.import": {
            "fg": "syntax.keyword"
        },
        "storage": {
            "fg": "syntax.keyword"
        },
        "function": {
            "fg": "syntax.function"
        },
        "function.call": {
            "fg": "syntax.function"
        },
        "method": {
            "fg": "syntax.function"
        },
        "type": {
            "fg": "syntax.type"
        },
        "type.builtin": {
            "fg": "syntax.type"
        },
        "class": {
            "fg": "syntax.type"
        },
        "interface": {
            "fg": "syntax.type"
        },
        "enum": {
            "fg": "syntax.type"
        },
        "namespace": {
            "fg": "syntax.namespace"
        },
        "constant": {
            "fg": "syntax.constant"
        },
        "constant.numeric": {
            "fg": "syntax.number"
        },
        "constant.boolean": {
            "fg": "syntax.constant"
        },
        "string": {
            "fg": "syntax.string"
        },
        "string.escape": {
            "fg": "syntax.stringEscape"
        },
        "regex": {
            "fg": "syntax.regex"
        },
        "comment": {
            "fg": "syntax.comment",
            "italic": true
        },
        "comment.doc": {
            "fg": "syntax.comment",
            "italic": true
        },
        "variable": {
            "fg": "syntax.variable"
        },
        "variable.parameter": {
            "fg": "syntax.parameter",
            "italic": true
        },
        "variable.language": {
            "fg": "syntax.languageVariable",
            "italic": true
        },
        "variable.constant": {
            "fg": "syntax.function"
        },
        "property": {
            "fg": "syntax.variable"
        },
        "operator": {
            "fg": "syntax.operator"
        },
        "punctuation": {
            "fg": "syntax.punctuation"
        },
        "tag": {
            "fg": "syntax.tag"
        },
        "tag.attribute": {
            "fg": "syntax.attribute"
        },
        "decorator": {
            "fg": "syntax.decorator"
        },
        "annotation": {
            "fg": "syntax.decorator"
        },
        "markup.heading": {
            "fg": "syntax.markupHeading"
        },
        "markup.bold": {
            "fg": "syntax.markupHeading",
            "bold": true
        },
        "markup.italic": {
            "fg": "syntax.keyword",
            "italic": true
        },
        "markup.link": {
            "fg": "syntax.markupLink"
        },
        "markup.code": {
            "fg": "syntax.markupCode"
        },
        "markup.quote": {
            "fg": "syntax.markupQuote"
        },
        "markup.list": {
            "fg": "syntax.markupHeading"
        },
        "diff.added": {
            "fg": "diff.addedFg"
        },
        "diff.removed": {
            "fg": "diff.removedFg"
        },
        "diff.changed": {
            "fg": "diff.changedFg"
        },
        "invalid": {
            "fg": "fg.inverse"
        },
        "deprecated": {
            "fg": "fg.disabled",
            "strikethrough": true
        }
    }
}