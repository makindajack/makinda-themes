{
  "name": "makinda-themes",
  "displayName": "Makinda Themes",
  "description": "Premium light and dark themes for VS Code with warm orange accents and excellent readability",
  "version": "1.1.0",
  "publisher": "makindajack",
  "icon": "images/icon.png",
  "author": {
    "name": "Jackson Makinda",
    "email": "jacksonmakinda@outlook.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/makindajack/makinda-themes#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/makindajack/makinda-themes"
  },
  "bugs": {
    "url": "https://github.com/makindajack/makinda-themes/issues",
    "email": "jacksonmakinda@outlook.com"
  },
  "keywords": [
    "theme",
    "light",
    "dark",
    "light theme",
    "dark theme",
    "orange",
    "makinda",
    "makinda light",
    "makinda dark",
    "makinda themes",
    "makindajack",
    "jackson makinda",
    "color theme",
    "syntax highlighting",
    "editor theme"
  ],
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Themes"
  ],
  "galleryBanner": {
    "color": "#271002",
    "theme": "dark"
  },
  "contributes": {
    "themes": [
      {
        "label": "Makinda Light",
        "uiTheme": "vs",
        "path": "./themes/Makinda Light-color-theme.json"
      },
      {
        "label": "Makinda Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/Makinda Dark-color-theme.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build && npm run check",
    "package": "vsce package",
    "publish": "vsce publish",
    "validate": "node build/validate.mjs",
    "validate:strict": "node build/validate.mjs --strict",
    "validate:json": "node build/validate.mjs --json",
    "contrast": "node build/contrast.mjs",
    "contrast:strict": "node build/contrast.mjs --strict",
    "check": "npm run validate:strict && npm run contrast",
    "build": "node build/index.mjs",
    "build:vscode": "node build/vscode.mjs",
    "build:jetbrains": "node build/jetbrains.mjs",
    "build:sublime": "node build/sublime.mjs",
    "build:zed": "node build/zed.mjs",
    "build:neovim": "node build/neovim.mjs",
    "build:xcode": "node build/xcode.mjs",
    "build:helix": "node build/helix.mjs",
    "build:textmate": "node build/textmate.mjs",
    "build:emacs": "node build/emacs.mjs",
    "build:notepad-plus-plus": "node build/notepad-plus-plus.mjs",
    "build:visual-studio": "node build/visual-studio.mjs",
    "build:eclipse": "node build/eclipse.mjs",
    "build:bbedit": "node build/bbedit.mjs",
    "build:nova": "node build/nova.mjs",
    "build:lapce": "node build/lapce.mjs",
    "build:alacritty": "node build/alacritty.mjs",
    "build:kitty": "node build/kitty.mjs",
    "build:warp": "node build/warp.mjs",
    "build:wezterm": "node build/wezterm.mjs",
    "build:ghostty": "node build/ghostty.mjs",
    "build:windows-terminal": "node build/windows-terminal.mjs",
    "build:iterm2": "node build/iterm2.mjs",
    "build:slack": "node build/slack.mjs",
    "build:discord": "node build/discord.mjs",
    "build:obsidian": "node build/obsidian.mjs",
    "screenshots": "node build/screenshots.mjs",
    "release": "node build/release.mjs"
  },
  "devDependencies": {
    "playwright": "^1.59.1",
    "shiki": "^4.0.2"
  }
}